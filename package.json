{
  "name": "convert-units",
  "version": "3.0.0-beta.8",
  "description": "Convert between quantities in different units",
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/esm/index.d.ts",
        "default": "./lib/esm/index.js"
      },
      "require": {
        "types": "./lib/cjs/index.d.ts",
        "default": "./lib/cjs/index.js"
      }
    },
    "./definitions/*": {
      "import": {
        "types": "./lib/esm/definitions/*.d.ts",
        "default": "./lib/esm/definitions/*.js"
      },
      "require": {
        "types": "./lib/cjs/definitions/*.d.ts",
        "default": "./lib/cjs/definitions/*.js"
      }
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint__js": "^9.14.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-prettier": "^3.1.3",
    "@types/jest": "^30.0.0",
    "decimal.js": "^10.6.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "expect-type": "^1.3.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "publint": "^0.3.18",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "publint": "publint",
    "format": "prettier --write src",
    "compile": "tsc -p ./tsconfig.json && tsc -p ./tsconfig.cjs.json && tsc -p ./tsconfig.umd.json"
  },
  "files": [
    "lib/esm/**/!(*.tsbuildinfo)",
    "lib/cjs/**/!(*.tsbuildinfo)",
    "lib/umd/**/!(*.tsbuildinfo)",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/convert-units/convert-units.git"
  },
  "keywords": [
    "metric",
    "imperial",
    "convert",
    "ratio",
    "fraction"
  ],
  "author": "Ben Ng <me@benng.me> (http://benng.me)",
  "license": "MIT",
  "overrides": {
    "diff": ">=8.0.3"
  }
}
